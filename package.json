{
  "name": "alpha",
  "version": "1.0.0",
  "description": "This project is a React frontend and FastAPI backend application.",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mwohlf/alpha.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/mwohlf/alpha/issues"
  },
  "homepage": "https://github.com/mwohlf/alpha#readme",
  "nx": {
    "targets": {
      "setup": {
        "executor": "nx:run-commands",
        "options": {
          "command": "node -e \"console.log('\\x1b[32m%s\\x1b[0m', '✔ Setup Start')\""        
        }
      },
      "clean": {
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "node -e \"console.log('\\x1b[32m%s\\x1b[0m', '✔ starting cleanup...')\"",    
            "rimraf ./frontend/node_modules",
            "rimraf ./backend/__pycache__",
            "rimraf ./backend/.venv",
            "rimraf ./backend/ollama_client",
            "rimraf ./.nx/cache",
            "rimraf ./.nx/installation"
          ]
        }      
      }
    }  
  },
  "devDependencies": {
    "rimraf": "^6.1.3"
  },
  "dependencies": {}
}
